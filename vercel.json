{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://$BACKEND_URL/wegasfinance/api/:path*"
    },
    {
      "source": "/wegasfinance/uploads/:path*",
      "destination": "https://$BACKEND_URL/wegasfinance/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
